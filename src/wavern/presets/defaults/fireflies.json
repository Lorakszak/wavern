{
  "name": "Fireflies (Beta)",
  "description": "[Beta] Tiny glowing particles spawning randomly with heavy turbulence and slow drift",
  "author": "wavern",
  "version": 1,
  "visualization": {
    "visualization_type": "particles",
    "params": {
      "max_particles": 3000,
      "particle_size": 6.0,
      "spawn_rate": 2.0,
      "lifetime": 10.0,
      "spread": 0.2,
      "spawn_mode": "random",
      "spawn_x": 0.5,
      "spawn_y": 0.5,
      "spawn_radius": 0.3,
      "gravity_x": 0.0,
      "gravity_y": 0.02,
      "speed_min": 0.01,
      "speed_max": 0.1,
      "drag": 0.5,
      "turbulence": 0.8,
      "radial_force": 0.0,
      "vortex": 0.0,
      "size_reactivity": 0.6,
      "speed_reactivity": 0.2,
      "color_shift_reactivity": 0.5,
      "size_over_life": "pulse",
      "fade_curve": "ease_out",
      "color_over_life": true
    }
  },
  "color_palette": ["#FFEE44", "#FFCC00", "#88FF44", "#44FF88", "#FFAA22"],
  "blend_mode": "additive",
  "background": {
    "type": "solid",
    "color": "#040804"
  },
  "overlay": {
    "title_enabled": false,
    "title_text": "",
    "countdown_enabled": false,
    "countdown_format": "elapsed_total",
    "link_positions": true,
    "title_x": 0.5,
    "title_y": 0.05,
    "countdown_x": 0.5,
    "countdown_y": 0.05,
    "font_family": "montserrat",
    "font_bold": false,
    "font_size": 28,
    "font_color": "#FFFFFF",
    "font_opacity": 1.0,
    "outline_enabled": false,
    "outline_color": "#000000",
    "outline_width": 2,
    "shadow_enabled": false,
    "shadow_color": "#000000",
    "shadow_opacity": 0.7,
    "shadow_offset_x": 3,
    "shadow_offset_y": 3
  },
  "fft_size": 4096,
  "smoothing": 0.7,
  "beat_sensitivity": 1.2,
  "fps": 60
}
