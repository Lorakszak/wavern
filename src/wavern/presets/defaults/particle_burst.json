{
  "name": "Particle Burst",
  "description": "Explosive particle effects driven by beats",
  "author": "wavern",
  "version": 1,
  "visualization": {
    "visualization_type": "particles",
    "params": {
      "max_particles": 3000,
      "particle_size": 5.0,
      "spawn_rate": 1.5,
      "lifetime": 2.5,
      "spread": 0.6,
      "gravity_y": -0.05
    }
  },
  "color_palette": ["#FFD700", "#FF4500", "#FF1493", "#00CED1"],
  "blend_mode": "additive",
  "background": {
    "type": "solid",
    "color": "#050505"
  },
  "overlay": {
    "title_enabled": false,
    "title_text": "",
    "countdown_enabled": false,
    "countdown_format": "elapsed_total",
    "link_positions": true,
    "title_x": 0.5,
    "title_y": 0.05,
    "countdown_x": 0.5,
    "countdown_y": 0.05,
    "font_family": "montserrat",
    "font_bold": false,
    "font_size": 28,
    "font_color": "#FFFFFF",
    "font_opacity": 1.0,
    "outline_enabled": false,
    "outline_color": "#000000",
    "outline_width": 2,
    "shadow_enabled": false,
    "shadow_color": "#000000",
    "shadow_opacity": 0.7,
    "shadow_offset_x": 3,
    "shadow_offset_y": 3
  },
  "fft_size": 2048,
  "smoothing": 0.25,
  "beat_sensitivity": 1.8,
  "fps": 60
}
