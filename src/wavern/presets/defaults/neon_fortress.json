{
  "name": "Neon Fortress",
  "description": "Diamond-oriented neon fortress with film grain and background blur",
  "author": "wavern",
  "version": 1,
  "color_palette": ["#00eeff", "#aa00ff", "#ff0099", "#ff6600", "#0066ff"],
  "background": {
    "type": "solid",
    "color": "#04000d",
    "movements": {
      "breathe": {
        "enabled": true,
        "speed": 0.7,
        "intensity": 0.25
      }
    },
    "effects": {
      "blur": {
        "enabled": true,
        "intensity": 0.18
      },
      "hue_shift": {
        "enabled": true,
        "intensity": 0.06
      }
    }
  },
  "global_effects": {
    "apply_stage": "before_overlays",
    "film_grain": {
      "enabled": true,
      "intensity": 0.35
    },
    "vignette": {
      "enabled": true,
      "intensity": 0.65,
      "shape": "circular"
    }
  },
  "fft_size": 8192,
  "smoothing": 0.82,
  "beat_sensitivity": 1.8,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "rect_spectrum",
      "params": {
        "bar_count": 128,
        "bar_spacing": 0.18,
        "inner_size": 0.22,
        "bar_length": 0.42,
        "rotates": true,
        "rotation_speed": 0.2,
        "rotation_offset": 45.0,
        "gravity": 0.88,
        "glow_intensity": 1.2,
        "continuous_colors": true,
        "mirror_sides": true,
        "mirror_half": "left",
        "frequency_limit": true,
        "max_frequency": 14000,
        "shape_beat_bounce": true,
        "shape_bounce_strength": 0.3,
        "min_bar_height": 0.008,
        "shadow_enabled": true,
        "shadow_color": "#3300aa",
        "shadow_opacity": 0.45,
        "shadow_offset_x": 0.004,
        "shadow_offset_y": -0.004,
        "shadow_size": 1.8,
        "shadow_blur": 0.018
      },
      "blend_mode": "additive",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": ["#00eeff", "#aa00ff", "#ff0099", "#ff6600", "#0066ff"]
    }
  ]
}
