{
  "name": "Deep Ocean Pulse",
  "description": "Dense circular spectrum with beat-bouncing ring, shadows, and wave background",
  "author": "wavern",
  "version": 1,
  "visualization": {
    "visualization_type": "circular_spectrum",
    "params": {
      "bar_count": 128,
      "bar_spacing": 0.15,
      "inner_radius": 0.18,
      "bar_length": 0.4,
      "rotation_speed": 0.5,
      "rotation_direction": "clockwise",
      "gravity": 0.9,
      "glow_intensity": 0.8,
      "mirror_spectrum": true,
      "mirror_half": "left",
      "shadow_enabled": true,
      "shadow_color": "#001122",
      "shadow_opacity": 0.5,
      "shadow_offset_x": 0.004,
      "shadow_offset_y": -0.006,
      "shadow_size": 1.3,
      "shadow_blur": 0.008,
      "shape_beat_bounce": true,
      "shape_bounce_strength": 0.2,
      "frequency_limit": true,
      "max_frequency": 12000
    }
  },
  "color_palette": [
    "#003366",
    "#0066cc",
    "#00aaff",
    "#33ddff",
    "#99eeff"
  ],
  "blend_mode": "additive",
  "background": {
    "type": "solid",
    "color": "#000a15",
    "movement": {
      "type": "wave",
      "speed": 0.6,
      "intensity": 0.3,
      "angle": 180.0
    }
  },
  "fft_size": 8192,
  "smoothing": 0.88,
  "beat_sensitivity": 1.8,
  "fps": 60
}
