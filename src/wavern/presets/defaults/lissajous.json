{
  "name": "Lissajous",
  "description": "Mathematical Lissajous figure with bloom and gradient background",
  "author": "wavern",
  "version": 1,
  "color_palette": ["#00CCFF", "#0066FF", "#8800FF", "#FF00CC", "#FF4488"],
  "background": {
    "type": "gradient",
    "gradient_stops": [
      {"position": 0.0, "color": "#000010"},
      {"position": 0.4, "color": "#0A0020"},
      {"position": 1.0, "color": "#000008"}
    ]
  },
  "global_effects": {
    "apply_stage": "before_overlays",
    "bloom": {
      "enabled": true,
      "intensity": 0.55,
      "threshold": 0.55,
      "audio": {
        "enabled": true,
        "source": "beat",
        "sensitivity": 1.4
      }
    },
    "vignette": {
      "enabled": true,
      "intensity": 0.45,
      "shape": "circular"
    }
  },
  "fft_size": 2048,
  "smoothing": 0.25,
  "beat_sensitivity": 1.2,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "lissajous",
      "params": {
        "waveform_smoothing": 12,
        "sample_count": 256,
        "delay_samples": 40,
        "amplitude_scale": 1.2,
        "symmetry": 4,
        "mirror_x": true,
        "spin_speed": 0.15,
        "line_thickness": 3.5,
        "glow_intensity": 1.4,
        "tail_fade": 0.5,
        "beat_reactive": true,
        "scale": 0.9,
        "rotation": 45.0
      },
      "blend_mode": "additive",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": ["#00CCFF", "#0066FF", "#8800FF", "#FF00CC", "#FF4488"]
    }
  ]
}
