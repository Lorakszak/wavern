{
  "name": "Bouncing Orbit",
  "description": "Beat-bouncing circular spectrum with fast counterclockwise spin, mirrored bars, and zoom pulse background",
  "author": "wavern",
  "version": 1,
  "color_palette": [
    "#00ffaa",
    "#00ddff",
    "#4488ff",
    "#8844ff",
    "#ff00cc"
  ],
  "background": {
    "type": "solid",
    "color": "#000a08",
    "movement": {
      "type": "zoom_pulse",
      "speed": 1.2,
      "intensity": 0.4,
      "angle": 0.0
    }
  },
  "fft_size": 4096,
  "smoothing": 0.8,
  "beat_sensitivity": 2.0,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "circular_spectrum",
      "params": {
        "bar_count": 128,
        "bar_spacing": 0.12,
        "inner_radius": 0.3,
        "bar_length": 0.35,
        "rotation_speed": 3.0,
        "rotation_direction": "counterclockwise",
        "gravity": 0.85,
        "glow_intensity": 1.8,
        "mirror_spectrum": true,
        "mirror_half": "left",
        "shape_beat_bounce": true,
        "shape_bounce_strength": 0.8,
        "frequency_limit": true,
        "max_frequency": 10000
      },
      "blend_mode": "additive",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": [
        "#00ffaa",
        "#00ddff",
        "#4488ff",
        "#8844ff",
        "#ff00cc"
      ]
    }
  ]
}
