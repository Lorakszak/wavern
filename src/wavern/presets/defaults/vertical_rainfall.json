{
  "name": "Vertical Rainfall",
  "description": "90-degree rotated mirrored bars with tight spacing and shadow \u2014 sideways rain effect",
  "author": "wavern",
  "version": 1,
  "color_palette": [
    "#0044ff",
    "#0088ff",
    "#00ccff",
    "#44eeff",
    "#aaffff"
  ],
  "background": {
    "type": "solid",
    "color": "#000510",
    "movement": {
      "type": "wave",
      "speed": 0.8,
      "intensity": 0.3,
      "angle": 90.0
    }
  },
  "fft_size": 4096,
  "smoothing": 0.82,
  "beat_sensitivity": 1.3,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "spectrum_bars",
      "params": {
        "bar_count": 128,
        "bar_spacing": 0.08,
        "mirror": true,
        "mirror_spectrum": true,
        "mirror_half": "left",
        "min_bar_height": 0.005,
        "max_bar_height": 0.85,
        "frequency_scale": "logarithmic",
        "gravity": 0.88,
        "color_mode": "position",
        "intensity": 1.1,
        "rotation": 90.0,
        "shadow_enabled": true,
        "shadow_color": "#003366",
        "shadow_opacity": 0.5,
        "shadow_offset_x": 0.0,
        "shadow_offset_y": -0.008,
        "shadow_size": 1.5,
        "shadow_blur": 0.02,
        "frequency_limit": true,
        "max_frequency": 8000
      },
      "blend_mode": "additive",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": [
        "#0044ff",
        "#0088ff",
        "#00ccff",
        "#44eeff",
        "#aaffff"
      ]
    }
  ]
}
