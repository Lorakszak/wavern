{
  "name": "Stardust Rain (Beta)",
  "description": "[Beta] 10000 tiny particles spawning from top, falling like rain with high drag and shake background",
  "author": "wavern",
  "version": 1,
  "visualization": {
    "visualization_type": "particles",
    "params": {
      "max_particles": 10000,
      "particle_size": 1.5,
      "spawn_rate": 8.0,
      "lifetime": 6.0,
      "spread": 2.0,
      "gravity_y": -0.8,
      "spawn_x": 0.5,
      "spawn_y": 0.95,
      "gravity_x": 0.0,
      "speed_min": 0.02,
      "speed_max": 0.15,
      "drag": 0.6
    }
  },
  "color_palette": [
    "#aaccff",
    "#ccddff",
    "#eeeeff",
    "#ffffff",
    "#88aadd"
  ],
  "blend_mode": "additive",
  "background": {
    "type": "solid",
    "color": "#020208",
    "movement": {
      "type": "shake",
      "speed": 2.0,
      "intensity": 0.15,
      "angle": 0.0
    }
  },
  "fft_size": 4096,
  "smoothing": 0.7,
  "beat_sensitivity": 1.5,
  "fps": 60
}
