{
  "name": "Spectrogram",
  "description": "Scrolling viridis frequency heatmap",
  "author": "wavern",
  "version": 1,
  "color_palette": ["#000000", "#440154", "#21908C", "#FDE725"],
  "background": {
    "type": "solid",
    "color": "#040408"
  },
  "fft_size": 4096,
  "smoothing": 0.15,
  "beat_sensitivity": 1.2,
  "fps": 60,
  "global_effects": {
    "apply_stage": "after_overlays",
    "vignette": {
      "enabled": true,
      "intensity": 0.35,
      "shape": "rectangular"
    }
  },
  "layers": [
    {
      "visualization_type": "spectrogram",
      "params": {
        "scroll_direction": "left",
        "scroll_speed": 1.0,
        "frequency_scale": "logarithmic",
        "frequency_limit": false,
        "min_frequency": 20,
        "max_frequency": 20000,
        "color_map": "viridis",
        "brightness": 1.3,
        "contrast": 1.4,
        "saturation": 1.1,
        "history_length": 512,
        "blur": 0.3,
        "bar_separation": false
      },
      "blend_mode": "normal",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": ["#000000", "#440154", "#21908C", "#FDE725"]
    }
  ]
}
