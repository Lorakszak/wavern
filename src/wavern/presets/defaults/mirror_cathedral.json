{
  "name": "Mirror Cathedral",
  "description": "Sparse mirrored bars with heavy gravity and a breathing gradient background",
  "author": "wavern",
  "version": 1,
  "color_palette": ["#e0d0ff", "#a080ff", "#6040cc", "#3020aa", "#ffffff"],
  "background": {
    "type": "gradient",
    "gradient_stops": [
      {"position": 0.0, "color": "#0d0d1a"},
      {"position": 0.5, "color": "#1a1a33"},
      {"position": 1.0, "color": "#0d0d1a"}
    ],
    "movements": {
      "breathe": {
        "enabled": true,
        "speed": 0.5,
        "intensity": 0.4
      }
    }
  },
  "global_effects": {
    "apply_stage": "before_overlays",
    "bloom": {
      "enabled": true,
      "intensity": 0.4,
      "threshold": 0.6
    }
  },
  "fft_size": 4096,
  "smoothing": 0.9,
  "beat_sensitivity": 1.2,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "spectrum_bars",
      "params": {
        "bar_count": 16,
        "bar_spacing": 0.4,
        "mirror": true,
        "min_bar_height": 0.01,
        "max_bar_height": 0.9,
        "frequency_scale": "linear",
        "gravity": 0.97,
        "color_mode": "position",
        "height_reference": "per_bar",
        "intensity": 1.0,
        "mirror_spectrum": true,
        "mirror_half": "left",
        "position_y": 0.5
      },
      "blend_mode": "normal",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": ["#e0d0ff", "#a080ff", "#6040cc", "#3020aa", "#ffffff"]
    }
  ]
}
