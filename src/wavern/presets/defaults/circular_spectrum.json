{
  "name": "Radial Pulse",
  "description": "Circular spectrum with slow rotation",
  "author": "wavern",
  "version": 1,
  "visualization": {
    "visualization_type": "circular_spectrum",
    "params": {
      "bar_count": 64,
      "inner_radius": 0.2,
      "bar_length": 0.3,
      "rotation_speed": 0.3,
      "gravity": 0.88
    }
  },
  "color_palette": ["#FF6B6B", "#4ECDC4", "#45B7D1", "#96CEB4"],
  "blend_mode": "additive",
  "background": {
    "type": "solid",
    "color": "#080810"
  },
  "fft_size": 4096,
  "smoothing": 0.4,
  "beat_sensitivity": 1.5,
  "fps": 60
}
