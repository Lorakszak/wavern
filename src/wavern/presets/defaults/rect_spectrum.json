{
  "name": "Square Pulse",
  "description": "Rectangular spectrum with bars around a rotating square",
  "author": "wavern",
  "version": 1,
  "visualization": {
    "visualization_type": "rect_spectrum",
    "params": {
      "bar_count": 64,
      "bar_spacing": 0.25,
      "inner_size": 0.25,
      "bar_length": 0.3,
      "rotates": true,
      "rotation_speed": 0.2,
      "gravity": 0.88,
      "mirror_half": "left",
      "continuous_colors": false,
      "bar_roundness": 0.0,
      "shadow_enabled": false,
      "shadow_color": "#000000",
      "shadow_opacity": 0.4,
      "shadow_offset_x": 0.005,
      "shadow_offset_y": -0.005,
      "shadow_size": 1.0,
      "shadow_blur": 0.005,
      "inner_image_path": "",
      "inner_image_padding": 0.0,
      "inner_image_beat_bounce": false,
      "inner_image_bounce_strength": 0.15,
      "inner_image_bounce_zoom": false,
      "shape_beat_bounce": false,
      "shape_bounce_strength": 0.15
    }
  },
  "color_palette": ["#A855F7", "#EC4899", "#F97316", "#FACC15"],
  "blend_mode": "additive",
  "background": {
    "type": "solid",
    "color": "#080810"
  },
  "overlay": {
    "title_enabled": false,
    "title_text": "",
    "countdown_enabled": false,
    "countdown_format": "elapsed_total",
    "link_positions": true,
    "title_x": 0.5,
    "title_y": 0.05,
    "countdown_x": 0.5,
    "countdown_y": 0.05,
    "font_family": "montserrat",
    "font_bold": false,
    "font_size": 28,
    "font_color": "#FFFFFF",
    "font_opacity": 1.0,
    "outline_enabled": false,
    "outline_color": "#000000",
    "outline_width": 2,
    "shadow_enabled": false,
    "shadow_color": "#000000",
    "shadow_opacity": 0.7,
    "shadow_offset_x": 3,
    "shadow_offset_y": 3
  },
  "fft_size": 4096,
  "smoothing": 0.4,
  "beat_sensitivity": 1.5,
  "fps": 60
}
