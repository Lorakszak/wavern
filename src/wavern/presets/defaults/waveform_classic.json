{
  "name": "Classic Waveform",
  "description": "Clean waveform line with glow effect",
  "author": "wavern",
  "version": 1,
  "visualization": {
    "visualization_type": "waveform",
    "params": {
      "line_thickness": 2.5,
      "filled": false,
      "sample_count": 512,
      "amplitude_scale": 1.5
    }
  },
  "color_palette": ["#00FFAA"],
  "blend_mode": "additive",
  "background": {
    "type": "solid",
    "color": "#050510"
  },
  "overlay": {
    "title_enabled": false,
    "title_text": "",
    "countdown_enabled": false,
    "countdown_format": "elapsed_total",
    "link_positions": true,
    "title_x": 0.5,
    "title_y": 0.05,
    "countdown_x": 0.5,
    "countdown_y": 0.05,
    "font_family": "montserrat",
    "font_bold": false,
    "font_size": 28,
    "font_color": "#FFFFFF",
    "font_opacity": 1.0,
    "outline_enabled": false,
    "outline_color": "#000000",
    "outline_width": 2,
    "shadow_enabled": false,
    "shadow_color": "#000000",
    "shadow_opacity": 0.7,
    "shadow_offset_x": 3,
    "shadow_offset_y": 3
  },
  "fft_size": 2048,
  "smoothing": 0.2,
  "beat_sensitivity": 1.0,
  "fps": 60
}
