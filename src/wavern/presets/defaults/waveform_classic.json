{
  "name": "Classic Waveform",
  "description": "Clean waveform line with glow effect",
  "author": "wavern",
  "version": 1,
  "visualization": {
    "visualization_type": "waveform",
    "params": {
      "line_thickness": 2.5,
      "filled": false,
      "sample_count": 512,
      "amplitude_scale": 1.5
    }
  },
  "color_palette": ["#00FFAA"],
  "blend_mode": "additive",
  "background": {
    "type": "solid",
    "color": "#050510"
  },
  "fft_size": 2048,
  "smoothing": 0.2,
  "beat_sensitivity": 1.0,
  "fps": 60
}
