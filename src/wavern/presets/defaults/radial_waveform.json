{
  "name": "Radial Waveform",
  "description": "Pulsing energy ring with beat-reactive chromatic aberration",
  "author": "wavern",
  "version": 1,
  "color_palette": ["#00AAFF", "#7700FF", "#FF00CC", "#FF6600"],
  "background": {
    "type": "solid",
    "color": "#0A0A1A"
  },
  "fft_size": 2048,
  "smoothing": 0.35,
  "beat_sensitivity": 1.6,
  "fps": 60,
  "global_effects": {
    "apply_stage": "before_overlays",
    "vignette": {
      "enabled": true,
      "intensity": 0.55,
      "shape": "circular"
    },
    "chromatic_aberration": {
      "enabled": true,
      "intensity": 0.4,
      "direction": "radial",
      "audio": {
        "enabled": true,
        "source": "beat",
        "sensitivity": 2.0
      }
    },
    "bloom": {
      "enabled": true,
      "intensity": 0.6,
      "threshold": 0.55,
      "audio": {
        "enabled": true,
        "source": "bass",
        "sensitivity": 1.5
      }
    }
  },
  "layers": [
    {
      "visualization_type": "radial_waveform",
      "params": {
        "sample_count": 512,
        "inner_radius": 0.22,
        "wave_amplitude": 0.35,
        "line_thickness": 2.5,
        "smoothing": 6,
        "filled": false,
        "rotation_speed": 0.3,
        "rotation_direction": "clockwise",
        "mirror_mode": "none",
        "glow_intensity": 1.2,
        "shape_beat_bounce": true,
        "shape_bounce_strength": 0.25
      },
      "blend_mode": "additive",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": ["#00AAFF", "#7700FF", "#FF00CC", "#FF6600"]
    }
  ]
}
