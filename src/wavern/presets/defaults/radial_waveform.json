{
  "name": "Radial Waveform",
  "description": "Audio waveform wrapped around a circle with beat-reactive pulse",
  "author": "wavern",
  "version": 1,
  "color_palette": [
    "#00D4FF",
    "#7B2FBE",
    "#FF2D95",
    "#FFB800"
  ],
  "background": {
    "type": "solid",
    "color": "#080810"
  },
  "overlay": {
    "title_enabled": false,
    "title_text": "",
    "countdown_enabled": false,
    "countdown_format": "elapsed_total",
    "link_positions": true,
    "title_x": 0.5,
    "title_y": 0.05,
    "countdown_x": 0.5,
    "countdown_y": 0.05,
    "font_family": "montserrat",
    "font_bold": false,
    "font_size": 28,
    "font_color": "#FFFFFF",
    "font_opacity": 1.0,
    "outline_enabled": false,
    "outline_color": "#000000",
    "outline_width": 2,
    "shadow_enabled": false,
    "shadow_color": "#000000",
    "shadow_opacity": 0.7,
    "shadow_offset_x": 3,
    "shadow_offset_y": 3
  },
  "fft_size": 2048,
  "smoothing": 0.3,
  "beat_sensitivity": 1.5,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "radial_waveform",
      "params": {
        "sample_count": 256,
        "inner_radius": 0.2,
        "wave_amplitude": 0.3,
        "line_thickness": 2.0,
        "smoothing": 8,
        "filled": false,
        "rotation_speed": 0.0,
        "rotation_direction": "clockwise",
        "mirror_mode": "mirror",
        "glow_intensity": 0.5,
        "rotation_offset": 0.0,
        "center_x": 0.0,
        "center_y": 0.0,
        "scale": 1.0,
        "inner_image_path": "",
        "inner_image_padding": 0.0,
        "inner_image_beat_bounce": false,
        "inner_image_bounce_strength": 0.15,
        "inner_image_bounce_zoom": false,
        "inner_image_rotation_speed": 0.0,
        "inner_image_rotation_direction": "clockwise",
        "shape_beat_bounce": true,
        "shape_bounce_strength": 0.15
      },
      "blend_mode": "additive",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": [
        "#00D4FF",
        "#7B2FBE",
        "#FF2D95",
        "#FFB800"
      ]
    }
  ]
}
