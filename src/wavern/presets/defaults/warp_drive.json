{
  "name": "Warp Drive",
  "description": "Tunnel with particle debris and beat-reactive bloom",
  "author": "wavern",
  "version": 1,
  "color_palette": ["#00E5FF", "#4400CC", "#8B00FF", "#FF1493"],
  "background": {
    "type": "solid",
    "color": "#020210",
    "movements": {
      "zoom_pulse": {
        "enabled": true,
        "speed": 1.5,
        "intensity": 0.3,
        "audio": {
          "enabled": true,
          "source": "beat",
          "sensitivity": 1.8
        }
      }
    }
  },
  "global_effects": {
    "apply_stage": "before_overlays",
    "bloom": {
      "enabled": true,
      "intensity": 0.8,
      "threshold": 0.5,
      "audio": {
        "enabled": true,
        "source": "beat",
        "sensitivity": 2.0
      }
    }
  },
  "fft_size": 2048,
  "smoothing": 0.4,
  "beat_sensitivity": 1.4,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "tunnel",
      "name": "Tunnel",
      "blend_mode": "normal",
      "opacity": 1.0,
      "visible": true,
      "colors": ["#00E5FF", "#4400CC", "#8B00FF", "#FF1493"],
      "params": {
        "ring_count": 28,
        "direction": "inward",
        "base_speed": 2.5,
        "bass_drive": 1.2,
        "beat_burst": 2.5,
        "ring_thickness": 0.22,
        "ring_gap": 0.5,
        "spiral_twist": 0,
        "perspective": 0.7,
        "depth_fade": 0.8,
        "color_cycle_speed": 0.8,
        "color_spread": 1.5,
        "glow_intensity": 1.0,
        "pulse_intensity": 0.8,
        "ring_shape": "circle"
      }
    },
    {
      "visualization_type": "particles",
      "name": "Debris",
      "blend_mode": "additive",
      "opacity": 0.75,
      "visible": true,
      "colors": ["#AADDFF", "#FFFFFF", "#CCE8FF"],
      "params": {
        "max_particles": 2500,
        "particle_size": 3.5,
        "spawn_rate": 1.8,
        "lifetime": 1.5,
        "spread": 1.0,
        "spawn_mode": "point",
        "gravity_x": 0.0,
        "gravity_y": 0.0,
        "speed_min": 0.15,
        "speed_max": 0.6,
        "drag": 0.0,
        "turbulence": 0.15,
        "radial_force": 0.08,
        "vortex": 0.0,
        "size_reactivity": 0.4,
        "speed_reactivity": 0.5,
        "color_shift_reactivity": 0.2,
        "size_over_life": "shrink",
        "fade_curve": "flash",
        "color_over_life": false
      }
    }
  ]
}
