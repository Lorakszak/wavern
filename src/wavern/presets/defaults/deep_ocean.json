{
  "name": "Deep Ocean",
  "description": "Bioluminescent particles radiating from center behind a sonar ring",
  "author": "wavern",
  "version": 1,
  "color_palette": ["#00AAFF", "#0055DD", "#22DDCC", "#0033AA"],
  "background": {
    "type": "solid",
    "color": "#000C1A",
    "movements": {
      "wave": {
        "enabled": true,
        "speed": 0.45,
        "intensity": 0.5,
        "angle": 165.0,
        "clamp_to_frame": true
      }
    },
    "effects": {
      "saturation": {
        "enabled": true,
        "intensity": 0.35
      }
    }
  },
  "global_effects": {
    "apply_stage": "after_overlays",
    "film_grain": {
      "enabled": true,
      "intensity": 0.18
    },
    "bloom": {
      "enabled": true,
      "intensity": 0.45,
      "threshold": 0.6,
      "audio": {
        "enabled": true,
        "source": "amplitude",
        "sensitivity": 1.2
      }
    },
    "chromatic_aberration": {
      "enabled": true,
      "intensity": 0.12,
      "direction": "radial"
    }
  },
  "fft_size": 8192,
  "smoothing": 0.82,
  "beat_sensitivity": 1.5,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "particles",
      "name": "Bioluminescence",
      "blend_mode": "screen",
      "opacity": 0.82,
      "visible": true,
      "colors": ["#88EEFF", "#22AAFF", "#0055CC", "#44FFDD"],
      "params": {
        "max_particles": 3500,
        "particle_size": 3.5,
        "spawn_rate": 2.5,
        "lifetime": 8.0,
        "spread": 0.8,
        "spawn_mode": "edges",
        "position_x": 0.5,
        "position_y": 0.5,
        "gravity_x": 0.0,
        "gravity_y": 0.0,
        "speed_min": 0.02,
        "speed_max": 0.1,
        "drag": 0.0,
        "turbulence": 0.35,
        "radial_force": 0.12,
        "vortex": 0.0,
        "size_reactivity": 0.6,
        "speed_reactivity": 0.5,
        "color_shift_reactivity": 0.35,
        "size_over_life": "shrink",
        "fade_curve": "ease_out",
        "color_over_life": true
      }
    },
    {
      "visualization_type": "circular_spectrum",
      "name": "Sonar Array",
      "blend_mode": "normal",
      "opacity": 1.0,
      "visible": true,
      "colors": ["#00AAFF", "#0055DD", "#22DDCC", "#0033AA"],
      "params": {
        "bar_count": 96,
        "bar_spacing": 0.22,
        "inner_radius": 0.19,
        "bar_length": 0.35,
        "rotation_speed": 0.35,
        "rotation_direction": "counterclockwise",
        "gravity": 0.91,
        "glow_intensity": 0.9,
        "min_bar_height": 0.01,
        "scale": 1.05,
        "frequency_limit": true,
        "max_frequency": 10000,
        "shape_beat_bounce": true,
        "shape_bounce_strength": 0.35,
        "shadow_enabled": true,
        "shadow_color": "#001428",
        "shadow_opacity": 0.45,
        "shadow_offset_x": 0.003,
        "shadow_offset_y": -0.004,
        "shadow_size": 1.2,
        "shadow_blur": 0.007,
        "inner_image_rotation_speed": 1.0,
        "inner_image_rotation_direction": "clockwise",
        "inner_image_beat_bounce": true,
        "inner_image_bounce_zoom": true
      }
    }
  ]
