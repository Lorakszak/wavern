{
  "name": "Smoky Waves",
  "description": "Layered fluid wave patterns with turbulence",
  "author": "wavern",
  "version": 1,
  "color_palette": [
    "#667eea",
    "#764ba2",
    "#f093fb",
    "#4facfe"
  ],
  "background": {
    "type": "solid",
    "color": "#06060F"
  },
  "overlay": {
    "title_enabled": false,
    "title_text": "",
    "countdown_enabled": false,
    "countdown_format": "elapsed_total",
    "link_positions": true,
    "title_x": 0.5,
    "title_y": 0.05,
    "countdown_x": 0.5,
    "countdown_y": 0.05,
    "font_family": "montserrat",
    "font_bold": false,
    "font_size": 28,
    "font_color": "#FFFFFF",
    "font_opacity": 1.0,
    "outline_enabled": false,
    "outline_color": "#000000",
    "outline_width": 2,
    "shadow_enabled": false,
    "shadow_color": "#000000",
    "shadow_opacity": 0.7,
    "shadow_offset_x": 3,
    "shadow_offset_y": 3
  },
  "fft_size": 2048,
  "smoothing": 0.4,
  "beat_sensitivity": 1.0,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "smoky_waves",
      "params": {
        "wave_count": 6,
        "speed": 1.2,
        "turbulence": 0.6,
        "thickness": 1.5
      },
      "blend_mode": "additive",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": [
        "#667eea",
        "#764ba2",
        "#f093fb",
        "#4facfe"
      ]
    }
  ]
}
