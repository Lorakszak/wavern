{
  "name": "Closing Walls (Beta)",
  "description": "[Beta] Particles converging inward from all screen edges with flash fade and pulsing size",
  "author": "wavern",
  "version": 1,
  "color_palette": [
    "#00FFAA",
    "#00CCFF",
    "#0066FF",
    "#AA00FF",
    "#FF00AA"
  ],
  "background": {
    "type": "solid",
    "color": "#020208"
  },
  "overlay": {
    "title_enabled": false,
    "title_text": "",
    "countdown_enabled": false,
    "countdown_format": "elapsed_total",
    "link_positions": true,
    "title_x": 0.5,
    "title_y": 0.05,
    "countdown_x": 0.5,
    "countdown_y": 0.05,
    "font_family": "montserrat",
    "font_bold": false,
    "font_size": 28,
    "font_color": "#FFFFFF",
    "font_opacity": 1.0,
    "outline_enabled": false,
    "outline_color": "#000000",
    "outline_width": 2,
    "shadow_enabled": false,
    "shadow_color": "#000000",
    "shadow_opacity": 0.7,
    "shadow_offset_x": 3,
    "shadow_offset_y": 3
  },
  "fft_size": 2048,
  "smoothing": 0.4,
  "beat_sensitivity": 2.5,
  "fps": 60,
  "layers": [
    {
      "visualization_type": "particles",
      "params": {
        "max_particles": 5000,
        "particle_size": 5.0,
        "spawn_rate": 6.0,
        "lifetime": 2.5,
        "spread": 0.5,
        "spawn_mode": "edges",
        "spawn_x": 0.5,
        "spawn_y": 0.5,
        "spawn_radius": 0.3,
        "gravity_x": 0.0,
        "gravity_y": 0.0,
        "speed_min": 0.05,
        "speed_max": 0.2,
        "drag": 0.1,
        "turbulence": 0.2,
        "radial_force": -0.4,
        "vortex": 0.15,
        "size_reactivity": 0.5,
        "speed_reactivity": 0.6,
        "color_shift_reactivity": 0.0,
        "size_over_life": "pulse",
        "fade_curve": "flash",
        "color_over_life": false
      },
      "blend_mode": "additive",
      "opacity": 1.0,
      "visible": true,
      "name": "",
      "colors": [
        "#00FFAA",
        "#00CCFF",
        "#0066FF",
        "#AA00FF",
        "#FF00AA"
      ]
    }
  ]
