{
  "name": "Monsoon (Beta)",
  "description": "[Beta] Heavy rain from a horizontal line with turbulent wind and spectral color shifting",
  "author": "wavern",
  "version": 1,
  "color_palette": [
    "#AADDFF",
    "#6699CC",
    "#334466",
    "#CCDDEE",
